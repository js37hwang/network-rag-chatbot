# google gemini 답변 생성용
GOOGLE_API_KEY=제미나이 api key 입력

# 임베딩 연산 장치 설정- cuda or cpu
EMBEDDING_DEVICE=cuda

# llm 구동 모드 설정 gimini or local
LLM_MODE=gimini

# llm 구동 모드가 local일 경우- ollama 주소 필요
LOCAL_LLM_URL=http://localhost:11434
LOCAL_MODEL_NAME=eeve-korean:10.8b

# index name
OPENSEARCH_INDEX_NAME=cicso_network_index

# 임베딩 모델명
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# opensearch url
OPENSEARCH_ENGEIN_URL=http://localhost:9200
OPENSEARCH_DASHBOARD_URL=http://localhost:5601

CORS_ORIGINS=*